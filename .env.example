# Provisioned by `CONVEX_AGENT_MODE=anonymous npx convex dev --once` locally.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# Clerk powers customer, business, and staff account entry.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_JWT_ISSUER_DOMAIN=

# Comma-separated Clerk user IDs. Customer/business signup never writes this value.
VUN_STAFF_USER_IDS=

# No real provider exists in this MVP. Production mode fails closed.
VUN_COMMUNICATIONS_ADAPTER=mock
VUN_DEMO_MODE=false
